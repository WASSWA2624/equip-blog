generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  @@map("user_role")
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
  @@map("post_status")
}

enum EditorialStage {
  GENERATED
  REVIEWED
  EDITED
  APPROVED
  @@map("editorial_stage")
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
  @@map("comment_status")
}

enum GenerationJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  @@map("generation_job_status")
}

enum ViewEventType {
  WEBSITE_VIEW
  PAGE_VIEW
  POST_VIEW
  @@map("view_event_type")
}

enum EquipmentLifecycleStatus {
  PLANNED
  DRAFT
  GENERATED
  EDITED
  UPDATED
  POSTED

  @@map("equipment_lifecycle_status")
}

enum SourceType {
  OFFICIAL_MANUFACTURER_WEBSITE
  OFFICIAL_PRODUCT_PAGE
  OFFICIAL_MANUAL
  OFFICIAL_DISTRIBUTOR_DOCUMENTATION
  TRUSTED_BIOMEDICAL_REFERENCE
  TRUSTED_PROFESSIONAL_SOCIETY
  REPUTABLE_EDUCATIONAL_INSTITUTION
  APPROVED_SEARCH_RESULT
  @@map("source_type")
}

model Locale {
  code             String            @id @db.VarChar(16)
  name             String            @db.VarChar(64)
  isActive         Boolean           @default(true) @map("is_active")
  isDefault        Boolean           @default(false) @map("is_default")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  postTranslations PostTranslation[]
  generationJobs   GenerationJob[]
  viewEvents       ViewEvent[]
  @@map("locale")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique @db.VarChar(191)
  name                    String                   @db.VarChar(191)
  passwordHash            String                   @db.VarChar(255) @map("password_hash")
  role                    UserRole
  isActive                Boolean                  @default(true) @map("is_active")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  adminSessions           AdminSession[]
  authoredPosts           Post[]
  commentModerationEvents CommentModerationEvent[]
  auditEvents             AuditEvent[]
  @@map("user")
}

model AdminSession {
  id            String   @id @default(cuid())
  userId        String @map("user_id")
  tokenHash     String   @unique @db.VarChar(64) @map("token_hash")
  expiresAt     DateTime @map("expires_at")
  invalidatedAt DateTime? @map("invalidated_at")
  createdAt     DateTime @default(now()) @map("created_at")
  lastUsedAt    DateTime @default(now()) @map("last_used_at")
  userAgent     String?  @db.VarChar(512) @map("user_agent")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("admin_session")
}

model Equipment {
  id               String            @id @default(cuid())
  name             String            @db.VarChar(191)
  normalizedName   String            @unique @db.VarChar(191) @map("normalized_name")
  slug             String            @unique @db.VarChar(191)
  description      String?           @db.LongText
  lifecycleStatus  EquipmentLifecycleStatus @default(PLANNED) @map("lifecycle_status")
  lifecycleNotes   String?           @db.LongText @map("lifecycle_notes")
  postedAt         DateTime?         @map("posted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  aliases          EquipmentAlias[]
  posts            Post[]
  models           Model[]
  sourceReferences SourceReference[]

  @@index([lifecycleStatus])
  @@map("equipment")
}

model EquipmentAlias {
  id              String    @id @default(cuid())
  equipmentId     String @map("equipment_id")
  alias           String    @db.VarChar(191)
  normalizedAlias String    @unique @db.VarChar(191) @map("normalized_alias")
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  @@map("equipment_alias")
}

model Post {
  id                 String             @id @default(cuid())
  equipmentId        String @map("equipment_id")
  slug               String             @unique @db.VarChar(191)
  status             PostStatus         @default(DRAFT)
  editorialStage     EditorialStage     @default(GENERATED) @map("editorial_stage")
  excerpt            String             @db.LongText
  featuredImageId    String? @map("featured_image_id")
  authorId           String @map("author_id")
  scheduledPublishAt DateTime? @map("scheduled_publish_at")
  publishedAt        DateTime? @map("published_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  equipment          Equipment          @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  featuredImage      MediaAsset?        @relation("PostFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  author             User               @relation(fields: [authorId], references: [id], onDelete: Restrict)
  translations       PostTranslation[]
  faults             Fault[]
  maintenanceTasks   MaintenanceTask[]
  sourceReferences   SourceReference[]
  comments           Comment[]
  generationJobs     GenerationJob[]
  categories         PostCategory[]
  tags               PostTag[]
  manufacturers      PostManufacturer[]
  viewEvents         ViewEvent[]

  @@index([status, publishedAt])
  @@index([status, scheduledPublishAt])
  @@map("post")
}

model PostTranslation {
  id                    String     @id @default(cuid())
  postId                String @map("post_id")
  locale                String     @db.VarChar(16)
  title                 String     @db.VarChar(255)
  contentMd             String     @db.LongText @map("content_md")
  contentHtml           String     @db.LongText @map("content_html")
  structuredContentJson Json @map("structured_content_json")
  excerpt               String     @db.LongText
  disclaimer            String     @db.LongText
  faqJson               Json @map("faq_json")
  isAutoTranslated      Boolean    @default(false) @map("is_auto_translated")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  post                  Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  localeRecord          Locale     @relation(fields: [locale], references: [code], onDelete: Restrict)
  seoRecord             SEORecord?

  @@unique([postId, locale])
  @@index([locale, postId])
  @@map("post_translation")
}

model Category {
  id          String         @id @default(cuid())
  name        String         @unique @db.VarChar(191)
  slug        String         @unique @db.VarChar(191)
  description String?        @db.LongText
  posts       PostCategory[]
  @@map("category")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique @db.VarChar(191)
  slug  String    @unique @db.VarChar(191)
  posts PostTag[]
  @@map("tag")
}

model Manufacturer {
  id                  String              @id @default(cuid())
  name                String              @db.VarChar(191)
  normalizedName      String              @db.VarChar(191) @map("normalized_name")
  slug                String              @unique @db.VarChar(191)
  primaryDomain       String              @db.VarChar(191) @map("primary_domain")
  headquartersCountry String?             @db.VarChar(64) @map("headquarters_country")
  branchCountriesJson Json? @map("branch_countries_json")
  rankingScore        Int                 @default(0) @map("ranking_score")
  aliases             ManufacturerAlias[]
  models              Model[]
  sourceReferences    SourceReference[]
  posts               PostManufacturer[]

  @@unique([normalizedName, primaryDomain])
  @@map("manufacturer")
}

model ManufacturerAlias {
  id              String       @id @default(cuid())
  manufacturerId  String @map("manufacturer_id")
  alias           String       @db.VarChar(191)
  normalizedAlias String       @db.VarChar(191) @map("normalized_alias")
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)

  @@unique([manufacturerId, normalizedAlias])
  @@map("manufacturer_alias")
}

model Model {
  id               String            @id @default(cuid())
  manufacturerId   String @map("manufacturer_id")
  equipmentId      String @map("equipment_id")
  name             String            @db.VarChar(191)
  normalizedName   String            @db.VarChar(191) @map("normalized_name")
  slug             String            @db.VarChar(191)
  latestKnownYear  Int? @map("latest_known_year")
  summary          String?           @db.LongText
  rankingScore     Int               @default(0) @map("ranking_score")
  manufacturer     Manufacturer      @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  equipment        Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  sourceReferences SourceReference[]

  @@unique([manufacturerId, slug])
  @@map("model")
}

model Fault {
  id              String @id @default(cuid())
  postId          String @map("post_id")
  title           String @db.VarChar(255)
  normalizedTitle String @db.VarChar(255) @map("normalized_title")
  cause           String @db.LongText
  symptoms        String @db.LongText
  remedy          String @db.LongText
  severity        String @db.VarChar(64)
  evidenceCount   Int    @default(0) @map("evidence_count")
  sortOrder       Int    @default(0) @map("sort_order")
  post            Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, normalizedTitle])
  @@map("fault")
}

model MaintenanceTask {
  id          String @id @default(cuid())
  postId      String @map("post_id")
  frequency   String @db.VarChar(128)
  title       String @db.VarChar(255)
  description String @db.LongText
  sortOrder   Int    @default(0) @map("sort_order")
  post        Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@map("maintenance_task")
}

model MediaAsset {
  id              String      @id @default(cuid())
  fileName        String?     @db.VarChar(255) @map("file_name")
  fileSizeBytes   Int? @map("file_size_bytes")
  storageDriver   String      @db.VarChar(32) @map("storage_driver")
  storageKey      String?     @db.VarChar(255) @map("storage_key")
  publicUrl       String?     @db.VarChar(2048) @map("public_url")
  localPath       String?     @db.VarChar(512) @map("local_path")
  sourceUrl       String?     @db.VarChar(2048) @map("source_url")
  sourceDomain    String?     @db.VarChar(191) @map("source_domain")
  alt             String?     @db.LongText
  caption         String?     @db.LongText
  mimeType        String?     @db.VarChar(191) @map("mime_type")
  width           Int?
  height          Int?
  attributionText String?     @db.LongText @map("attribution_text")
  licenseType     String?     @db.VarChar(128) @map("license_type")
  usageNotes      String?     @db.LongText @map("usage_notes")
  isAiGenerated   Boolean     @default(false) @map("is_ai_generated")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  variants        MediaVariant[]
  featuredInPosts Post[]      @relation("PostFeaturedImage")
  seoOgRecords    SEORecord[] @relation("SeoOgImage")
  @@map("media_asset")
}

model MediaVariant {
  id            String     @id @default(cuid())
  mediaAssetId  String @map("media_asset_id")
  variantKey    String     @db.VarChar(64) @map("variant_key")
  format        String     @db.VarChar(32)
  mimeType      String?    @db.VarChar(191) @map("mime_type")
  width         Int
  height        Int
  fileSizeBytes Int? @map("file_size_bytes")
  storageKey    String?    @db.VarChar(255) @map("storage_key")
  publicUrl     String?    @db.VarChar(2048) @map("public_url")
  localPath     String?    @db.VarChar(512) @map("local_path")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  mediaAsset    MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@index([mediaAssetId, variantKey])
  @@map("media_variant")
}

model SourceReference {
  id              String        @id @default(cuid())
  postId          String? @map("post_id")
  equipmentId     String? @map("equipment_id")
  manufacturerId  String? @map("manufacturer_id")
  modelId         String? @map("model_id")
  title           String        @db.VarChar(255)
  url             String        @db.VarChar(2048)
  sourceDomain    String        @db.VarChar(191) @map("source_domain")
  sourceType      SourceType @map("source_type")
  fileType        String?       @db.VarChar(64) @map("file_type")
  language        String?       @db.VarChar(32)
  accessStatus    String?       @db.VarChar(64) @map("access_status")
  reliabilityTier String?       @db.VarChar(64) @map("reliability_tier")
  lastCheckedAt   DateTime? @map("last_checked_at")
  notes           String?       @db.LongText
  excerpt         String?       @db.LongText
  post            Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)
  equipment       Equipment?    @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  manufacturer    Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  model           Model?        @relation(fields: [modelId], references: [id], onDelete: SetNull)
  @@map("source_reference")
}

model Comment {
  id               String                   @id @default(cuid())
  postId           String @map("post_id")
  parentId         String? @map("parent_id")
  name             String                   @db.VarChar(191)
  email            String?                  @db.VarChar(191)
  body             String                   @db.LongText
  status           CommentStatus            @default(PENDING)
  ipHash           String                   @db.VarChar(255) @map("ip_hash")
  userAgent        String?                  @db.VarChar(512) @map("user_agent")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  post             Post                     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent           Comment?                 @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies          Comment[]                @relation("CommentReplies")
  moderationEvents CommentModerationEvent[]
  @@map("comment")
}

model CommentModerationEvent {
  id        String   @id @default(cuid())
  commentId String @map("comment_id")
  actorId   String? @map("actor_id")
  action    String   @db.VarChar(64)
  notes     String?  @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  @@map("comment_moderation_event")
}

model GenerationJob {
  id                  String              @id @default(cuid())
  postId              String? @map("post_id")
  equipmentName       String              @db.VarChar(191) @map("equipment_name")
  locale              String              @db.VarChar(16)
  providerConfigId    String @map("provider_config_id")
  status              GenerationJobStatus @default(PENDING)
  currentStage        String?             @db.VarChar(128) @map("current_stage")
  requestJson         Json @map("request_json")
  responseJson        Json? @map("response_json")
  warningJson         Json? @map("warning_json")
  errorMessage        String?             @db.LongText @map("error_message")
  replaceExistingPost Boolean             @default(false) @map("replace_existing_post")
  schedulePublishAt   DateTime? @map("schedule_publish_at")
  startedAt           DateTime? @map("started_at")
  finishedAt          DateTime? @map("finished_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  post                Post?               @relation(fields: [postId], references: [id], onDelete: SetNull)
  localeRecord        Locale              @relation(fields: [locale], references: [code], onDelete: Restrict)
  providerConfig      ModelProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  @@map("generation_job")
}

model PromptTemplate {
  id                 String   @id @default(cuid())
  name               String   @db.VarChar(191)
  purpose            String   @db.VarChar(64)
  version            Int
  systemPrompt       String   @db.LongText @map("system_prompt")
  userPromptTemplate String   @db.LongText @map("user_prompt_template")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([purpose, version])
  @@map("prompt_template")
}

model SourceConfig {
  id                 String     @id @default(cuid())
  name               String     @db.VarChar(191)
  sourceType         SourceType @unique @map("source_type")
  priority           Int
  isEnabled          Boolean    @default(true) @map("is_enabled")
  allowedDomainsJson Json @map("allowed_domains_json")
  notes              String?    @db.LongText
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  @@map("source_config")
}

model ModelProviderConfig {
  id             String          @id @default(cuid())
  provider       String          @db.VarChar(64)
  model          String          @db.VarChar(128)
  purpose        String          @db.VarChar(64)
  apiKeyEnvName  String          @db.VarChar(64) @map("api_key_env_name")
  apiKeyEncrypted String?        @db.LongText @map("api_key_encrypted")
  apiKeyLast4    String?         @db.VarChar(8) @map("api_key_last4")
  apiKeyUpdatedAt DateTime? @map("api_key_updated_at")
  isDefault      Boolean         @default(false) @map("is_default")
  isEnabled      Boolean         @default(true) @map("is_enabled")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  generationJobs GenerationJob[]

  @@unique([provider, model, purpose])
  @@map("model_provider_config")
}

model SEORecord {
  id                 String          @id @default(cuid())
  postTranslationId  String          @unique @map("post_translation_id")
  canonicalUrl       String          @db.VarChar(2048) @map("canonical_url")
  metaTitle          String          @db.VarChar(255) @map("meta_title")
  metaDescription    String          @db.LongText @map("meta_description")
  ogTitle            String          @db.VarChar(255) @map("og_title")
  ogDescription      String          @db.LongText @map("og_description")
  ogImageId          String? @map("og_image_id")
  twitterTitle       String          @db.VarChar(255) @map("twitter_title")
  twitterDescription String          @db.LongText @map("twitter_description")
  keywordsJson       Json @map("keywords_json")
  authorsJson        Json @map("authors_json")
  noindex            Boolean         @default(false)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  postTranslation    PostTranslation @relation(fields: [postTranslationId], references: [id], onDelete: Cascade)
  ogImage            MediaAsset?     @relation("SeoOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
  @@map("seo_record")
}

model ViewEvent {
  id           String        @id @default(cuid())
  postId       String? @map("post_id")
  path         String        @db.VarChar(2048)
  locale       String        @db.VarChar(16)
  eventType    ViewEventType @map("event_type")
  ipHash       String        @db.VarChar(255) @map("ip_hash")
  userAgent    String?       @db.VarChar(512) @map("user_agent")
  referrer     String?       @db.VarChar(2048)
  createdAt    DateTime      @default(now()) @map("created_at")
  post         Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)
  localeRecord Locale        @relation(fields: [locale], references: [code], onDelete: Restrict)

  @@index([eventType, createdAt])
  @@index([postId, createdAt])
  @@map("view_event")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String? @map("actor_id")
  entityType  String   @db.VarChar(64) @map("entity_type")
  entityId    String   @db.VarChar(191) @map("entity_id")
  action      String   @db.VarChar(64)
  payloadJson Json? @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  @@map("audit_event")
}

model PostCategory {
  postId     String @map("post_id")
  categoryId String @map("category_id")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
  @@map("post_category")
}

model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tag")
}

model PostManufacturer {
  postId         String @map("post_id")
  manufacturerId String @map("manufacturer_id")
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)

  @@id([postId, manufacturerId])
  @@index([manufacturerId])
  @@map("post_manufacturer")
}

